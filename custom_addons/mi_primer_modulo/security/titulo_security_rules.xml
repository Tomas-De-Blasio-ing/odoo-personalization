<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1"> <!-- Evitar que se sobreescriba 
                            el código en cada actualización-->
        
        <record id="rule_titulo_empleado" model="ir.rule"> 
            <!-- Nombre que aparece en los ajustes técnicos-->
            <field name="name">Títulos: Ver solo los que me pertenecen a mi</field>
            
            <!-- Indica a que base corresponde el filtro.
                Se compone el nombre del modelo por model_ seguido del nombre de 
                la tabla, reemplazando los '.' por '_'-->
            <field name="model_id" ref="model_ministerio_titulo"/>
            
            <!-- Funciona como consulta SQL.
                Se filtran los títulos correspondiente a de quién es el título, solo se verán los títulos propios.
                employee_id.user_id: devuelve el id que aparece en el campo employee_id de un título.
                user.id: es una variable global dinámica, represetna al id del usuario que está mirando la pantalla en ese momento-->
            <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
            

            <!-- Se define a quien afecta la regla (si no se agrega, afecta a todos, hasta al superusuario)
                base.group_user es el id del grupo 'Usuario Interno' (cualquier empleado)
                (4, ) comando del ORM de Odoo para relaciones M2M-->
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            
            <!-- Permisos CRUD -->
            <!-- 1 se aplica, 0 no se aplica.
                Por ejemplo, no se puede ver, no se puede escribir,
                ni borrar títulos que no sean tuyos. -->
            <field name="perm_read" eval="1"/> 
            <field name="perm_write" eval="1"/>
            <!-- Solo lógica, crear archivos en general se da en ir.model.acces.csv-->
            <field name="perm_create" eval="0"/> 
            <field name="perm_unlink" eval="1"/>
        </record>


        <record id="rule_titulo_admin" model="ir.rule"> 
            <field name="name">Títulos: Administradores ven todo</field>
            <field name="model_id" ref="model_ministerio_titulo"/>
            
            <!--Siempre verdadero para todos los administradores-->
            <field name="domain_force">[(1, '=', 1)]</field>
            
            <!--hr.group_hr_manager, pertenece a el grupo de administradores-->
            <field name="groups" eval="[(4, ref('hr.group_hr_manager'))]"/>
            
            <field name="perm_read" eval="1"/> 
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="0"/> 
            <field name="perm_unlink" eval="1"/>
        </record>
    </data>
</odoo>
